{
  "name": "jsonl-vision",
  "version": "0.1.0",
  "displayName": "JSONL Vision",
  "description": "View and edit a single line of a JSONL/NDJSON file as an interactive, warm-themed node graph.",
  "publisher": "jsonl-vision",
  "license": "MIT",
  "icon": "assets/icon.png",
  "author": {
    "name": "JSONL Vision"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cyclone-mind/jsonl-vision"
  },
  "bugs": {
    "url": "https://github.com/cyclone-mind/jsonl-vision/issues"
  },
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "jsonl",
    "ndjson",
    "jsonlines",
    "json",
    "visualizer",
    "graph",
    "editor"
  ],
  "activationEvents": [
    "workspaceContains:**/*.{json,jsonl,ndjson,jsonlines}"
  ],
  "main": "./build/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jsonl-vision.start",
        "title": "Enable JSONL Vision",
        "category": "menubar",
        "icon": {
          "light": "./assets/icon-light.svg",
          "dark": "./assets/icon-dark.svg"
        }
      },
      {
        "command": "jsonl-vision.start.specific",
        "title": "Enable JSONL Vision for specific file",
        "category": "menubar"
      },
      {
        "command": "jsonl-vision.start.selected",
        "title": "Open with JSONL Vision",
        "category": "Navigation"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "jsonl-vision.start.selected",
          "when": "editorHasSelection",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "jsonl-vision.start",
          "when": "never"
        }
      ],
      "editor/title": [
        {
          "command": "jsonl-vision.start",
          "when": "resourceExtname == .json || resourceExtname == .jsonl || resourceExtname == .ndjson || resourceExtname == .jsonlines || editorLangId == json || editorLangId == jsonl",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && node esbuild.config.mjs --production",
    "vsc:package": "pnpm run build && vsce package --no-dependencies",
    "build:dev": "vite build && node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "watch:webview": "vite build --watch",
    "lint": "eslint src ext-src && prettier --check src ext-src",
    "lint:fix": "eslint --fix src ext-src && prettier --write src ext-src",
    "clean": "rm -rf build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mantine/code-highlight": "^8.3.18",
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.11",
    "@types/react-dom": "19.2.3",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.25.12",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.4.2"
  },
  "dependencies": {
    "jsoncrack-react": "workspace:*",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shiki": "^4.0.2"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "packageManager": "pnpm@10.20.0"
}
